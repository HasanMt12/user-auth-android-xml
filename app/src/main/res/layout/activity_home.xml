<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:id="@+id/homeMain"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA"
    android:padding="16dp">

    <!-- ================= NAVBAR SECTION ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/calm_blue_gradient"
        android:weightSum="10">

        <ImageView
            android:id="@+id/iconCamera"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1.5"
            android:src="@android:drawable/ic_menu_camera"
            android:contentDescription="Camera" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="7"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/edit_text_border"
            android:hint="Search here..."
            android:textAlignment="center"
            android:textSize="14sp"
            android:inputType="text"
            android:padding="8dp" />

        <ImageView
            android:id="@+id/iconMenu"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1.5"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="Menu" />
    </LinearLayout>

    <!-- স্পেসার -->
    <View
        android:layout_width="match_parent"
        android:layout_height="16dp" />

    <!-- ================= TOP SECTION (2 POSTS SIDE BY SIDE) ================= -->
    <!-- layout_weight="4" -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:orientation="horizontal"
        android:weightSum="2">


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="5"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_kotlin"
                android:background="#E2E8F0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="5"
                android:layout_marginTop="8dp"
                android:text="Kotlin Coroutines\nLearn async programming basics easily."
                android:textColor="#1A202C"
                android:textSize="13sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="4" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:orientation="vertical">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="5"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_compose"
                android:background="#E2E8F0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="5"
                android:layout_marginTop="8dp"
                android:text="Jetpack Compose\nModern declarative UI framework for Android."
                android:textColor="#1A202C"
                android:textSize="13sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="4" />
        </LinearLayout>
    </LinearLayout>

    <!-- স্পেসার -->
    <View
        android:layout_width="match_parent"
        android:layout_height="16dp" />

    <!-- ================= BOTTOM SECTION (1 BIG HORIZONTAL POST) ================= -->
    <!-- layout_weight="4.5"  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4.5"
        android:background="@drawable/card_bg"
        android:padding="16dp"
        android:orientation="horizontal"
        android:weightSum="10">

        <!-- বাম পাশে বড় ফটো (৪০% জায়গা নেবে) -->
        <ImageView
            android:id="@+id/bigPostImage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_kotlin"
            android:background="#E9ECEF"
            android:contentDescription="Android &amp; Kotlin" />

        <!-- ডান পাশে টেক্সট কন্টেন্ট (৬০% জায়গা নেবে) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="6"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Why Kotlin rules Android Development"
                android:textColor="#212529"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Google officially supports Kotlin for building secure, boilerplate-free, and high-performance Android applications. Its safety features prevent major app crashes instantly."
                android:textColor="#4A5568"
                android:textSize="13sp"
                android:ellipsize="end"
                android:maxLines="6" />
        </LinearLayout>
    </LinearLayout>

    <!-- নিচের খালি অংশ ব্যালেন্স করার জন্য একটি রেসপন্সিভ স্পেসার -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5" />

</LinearLayout>